<resources>

    <!-- Text appearance for headings -->
    <style name="Jalkster.TextView.Heading" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Text appearance for body -->
    <style name="Jalkster.TextView.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Material button with purple background -->
    <style name="Jalkster.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/purple_500</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Outlined button variant -->
    <style name="Jalkster.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/purple_200</item>
        <item name="strokeColor">@color/purple_200</item>
    </style>

    <!-- CardView with dark background -->
    <style name="Jalkster.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/black</item>
        <item name="strokeColor">@color/purple_700</item>
    </style>

    <!-- EditText field styling -->
    <style name="Jalkster.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/purple_200</item>
        <item name="hintTextColor">@color/purple_200</item>
        <item name="android:textColor">@color/white</item>
    </style>

</resources>
